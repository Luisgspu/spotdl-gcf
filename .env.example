# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# ── Spotify ────────────────────────────────────────────────────────────────────
# From https://developer.spotify.com/dashboard → your app → Settings
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── GCS ────────────────────────────────────────────────────────────────────────
GCS_BUCKET=dj-gig-tracks-2026

# ── Tidal ──────────────────────────────────────────────────────────────────────
# Windows Bearer token — copy from openapi.tidal.com DevTools → Network tab →
# any authenticated request → Authorization header (strip the "Bearer " prefix).
# Refresh when expired (~yearly for web tokens).
TIDAL_ACCESS_TOKEN=eyJraWQi...your_token_here

# ── Soulseek ───────────────────────────────────────────────────────────────────
# Free account at www.slsknet.org
SOULSEEK_USERNAME=your_soulseek_username
SOULSEEK_PASSWORD=your_soulseek_password
